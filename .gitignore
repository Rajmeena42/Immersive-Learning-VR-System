# This .gitignore file is automatically generated for Unity projects.
# Source: https://github.com/github/gitignore/blob/main/Unity.gitignore

# [Bb]uild/
[Bb]uild/
[Bb]uilds/
[Ll]og/
[Ll]ogs/
[Mm]emoryCaptures/

# Never git ignore Assets, Packages, and ProjectSettings folders
!/[Aa]ssets/
!/[Pp]rojectSettings/
!/[Pp]ackages/

# Ignore Asset Store cache
/[Aa]ssetStoreTools*

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.tlog

# Unity Editor Folder Templates
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[UserSettings]/

# Visual Studio cache directory
.vs/

# Crashlytics generated file
crashlytics-build.properties

# Packed assets
/[Aa]ssets/[Aa]ddressableAssetsData/*/[Ll]ayout.bin
/[Aa]ssets/[Aa]ddressableAssetsData/*/[Cc]onfig.bin

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
